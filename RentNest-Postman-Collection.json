              "raw": "{{base_url}}/api/properties/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "properties", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "property_uuid_here"
                }
              ]
            }
          }
        },
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "header": [],
