{
  "compilerOptions": {
    "outDir": "./dist",
    "module": "ESNext",
    "target": "ES2023",
    "types": ["node"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "isolatedModules": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "moduleDetection": "force"
  },
  // "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "generated/prisma"]
}
