    {
      "name": "Landlord Properties",
      "item": [
        {
          "name": "Create Property Listing",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Luxury Studio Apartment\",\n  \"description\": \"Fully furnished apartment in the city center.\",\n  \"location\": \"Banani, Dhaka\",\n  \"price\": 500,\n  \"categoryId\": \"category_uuid_here\",\n  \"amenities\": [\"WiFi\", \"Air Conditioning\", \"Security\"],\n  \"images\": [\"https://example.com/image1.jpg\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/landlord/properties",
              "host": ["{{base_url}}"],
              "path": ["api", "landlord", "properties"]
            }
          }
        },
        {
          "name": "Update Property Listing",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Luxury Apartment\",\n  \"price\": 550,\n  \"availability\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/landlord/properties/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "landlord", "properties", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "property_uuid_here"
                }
              ]
            }
          }
        },
        {
          "name": "Delete Property Listing",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/landlord/properties/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "landlord", "properties", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "property_uuid_here"
                }
              ]
            }
          }
        }
      ]
