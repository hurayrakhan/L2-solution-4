    {
      "name": "Properties (Public)",
      "item": [
        {
          "name": "Browse Available Properties",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/properties?location=Dhaka&minPrice=100&maxPrice=1000",
              "host": ["{{base_url}}"],
              "path": ["api", "properties"],
              "query": [
                {
                  "key": "location",
                  "value": "Dhaka"
                },
                {
                  "key": "minPrice",
                  "value": "100"
                },
                {
                  "key": "maxPrice",
                  "value": "1000"
                }
              ]
            }
          }
        },
        {
          "name": "Get Property Details",
          "request": {
            "method": "GET",
            "header": [],
